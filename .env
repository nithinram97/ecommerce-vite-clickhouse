# ── HyperDX / ClickStack ────────────────────────────────────────────────────
# Get from: http://localhost:8080 → Team Settings → API Keys
HYPERDX_API_KEY=Authorization=Bearer <your-hyperdx-api-key>

# ── LibreChat / AI Assistant ─────────────────────────────────────────────────
# Add at least ONE AI provider key — LibreChat supports many providers.
# OpenAI (most common):
# OPENAI_API_KEY=sk-...
# AI NAtive Key:
AINATIVE_API_KEY=
# Google Gemini:
GOOGLE_KEY=


# Which model the shopping assistant uses (must match a model your key has access to)
LIBRECHAT_MODEL=gemini-2.5-flash-lite

# LibreChat internals — change in production
MEILI_MASTER_KEY=meili-master-key-changeme
JWT_SECRET=librechat-jwt-secret-changeme
JWT_REFRESH_SECRET=librechat-jwt-refresh-changeme